# Local overrides for scripts/deploy-opencode-agents.sh
# Copy this file to .opencode-deploy.local.env and adjust values.

# Source directory for agent markdown files.
# Relative paths are resolved from repo root.
OPENCODE_DEPLOY_SOURCE_DIR=agents

# OpenCode config directory. If unset, script uses `opencode debug paths` -> config.
# OPENCODE_DEPLOY_CONFIG_DIR=~/.config/opencode

# OpenCode agents directory. If unset, defaults to <config>/agents.
# OPENCODE_DEPLOY_AGENTS_DIR=~/.config/opencode/agents

# Install mode: symlink (recommended) or copy.
OPENCODE_DEPLOY_MODE=symlink
